{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "strict": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": false,
    "baseUrl": ".",
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "main.js",
    "preload.js",
    "renderer.js",
    "src/**/*.js",
    "src/**/*.ts",
    "src/**/*.d.ts",
    "scripts/**/*.js",
    "scripts/**/*.ts"
  ],
  "exclude": [
    "dist",
    "release",
    "node_modules"
  ]
}
