{
  "name": "BD-SCANNER",
  "version": "2.1.0",
  "description": "BD-Scanner",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "verify:structure": "node scripts/verify-structure.js",
    "verify:runtime-sync": "node scripts/verify-runtime-sync-safety.js",
    "test": "npm run verify:structure && npm run verify:runtime-sync",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "ts:preview": "tsc -p tsconfig.runtime-preview.json",
    "ts:preview:main-ipc": "tsc -p tsconfig.runtime-preview-main-ipc.json",
    "ts:verify": "node scripts/verify-ts-preview.js",
    "ts:verify:main-ipc": "node scripts/verify-main-ipc-cjs-preview.js",
    "ts:preview:main-bootstrap": "tsc -p tsconfig.runtime-preview-main-bootstrap.json",
    "ts:verify:main-bootstrap": "node scripts/verify-main-bootstrap-cjs-preview.js",
    "ts:sync:main-held-bootstrap": "node scripts/sync-runtime-main-held-bootstrap.js",
    "ts:sync:main-ipc-auth": "node scripts/sync-runtime-main-ipc-auth.js",
    "ts:sync:main-ipc-firestore": "node scripts/sync-runtime-main-ipc-firestore.js",
    "ts:sync:main-ipc-app": "node scripts/sync-runtime-main-ipc-app.js",
    "ts:sync:main-ipc-ios": "node scripts/sync-runtime-main-ipc-ios.js",
    "ts:sync:main-ipc-android": "node scripts/sync-runtime-main-ipc-android.js",
    "ts:sync:shared-first-wave": "node scripts/sync-runtime-shared-first-wave.js",
    "ts:sync:renderer-app-first-wave": "node scripts/sync-runtime-renderer-app-first-wave.js",
    "ts:sync:renderer-auth-device": "node scripts/sync-runtime-renderer-feature-auth-device.js",
    "ts:sync:renderer-appdetail-actions": "node scripts/sync-runtime-renderer-appdetail-actions.js",
    "ts:sync:renderer-scan-small": "node scripts/sync-runtime-renderer-scan-small.js",
    "ts:sync:renderer-scan-medium": "node scripts/sync-runtime-renderer-scan-medium.js",
    "ts:sync:renderer-scan-results-renderer": "node scripts/sync-runtime-renderer-scan-results-renderer.js",
    "ts:sync:renderer-scan-orchestration": "node scripts/sync-runtime-renderer-scan-orchestration.js",
    "ts:sync:renderer-scan-held-methods": "node scripts/sync-runtime-renderer-scan-held-methods.js",
    "ts:sync:renderer-scan-held-core": "node scripts/sync-runtime-renderer-scan-held-core.js",
    "ts:sync:renderer-scan-held-init-runtime": "node scripts/sync-runtime-renderer-scan-held-init-runtime.js",
    "ts:sync:renderer-scan-held-init-controller": "node scripts/sync-runtime-renderer-scan-held-init-controller.js",
    "ts:sync:main-helper-first-wave": "node scripts/sync-runtime-main-helper-first-wave.js",
    "ts:sync:main-helper-second-wave": "node scripts/sync-runtime-main-helper-second-wave.js",
    "ts:sync:main-helper-third-wave": "node scripts/sync-runtime-main-helper-third-wave.js",
    "ts:sync:main-helper-fourth-wave": "node scripts/sync-runtime-main-helper-fourth-wave.js",
    "ts:sync:main-helper-final-wave": "node scripts/sync-runtime-main-helper-final-wave.js",
    "ts:sync:main-service-light-wave": "node scripts/sync-runtime-main-service-light-wave.js",
    "ts:sync:main-held-android-service": "node scripts/sync-runtime-main-held-android-service.js",
    "ts:sync:main-held-ios-service": "node scripts/sync-runtime-main-held-ios-service.js",
    "ts:sync:main-core-light-wave": "node scripts/sync-runtime-main-core-light-wave.js",
    "ts:sync:main-shell-light-wave": "node scripts/sync-runtime-main-shell-light-wave.js",
    "ts:sync:main-testing-wave": "node scripts/sync-runtime-main-testing-wave.js",
    "ts:sync:main-ipc-first-wave": "node scripts/sync-runtime-main-ipc-first-wave.js",
    "reinstall:electron": "node scripts/reinstall-electron.js",
    "build": "npm run verify:structure && electron-builder --dir",
    "pack": "npm run verify:structure && electron-builder",
    "deploy:xos": "electron-builder --mac",
    "deploy:win32": "electron-builder --win --ia32",
    "deploy:win64": "electron-builder --win --x64 --publish always",
    "deploy:win": "npm run deploy:win32 && npm run deploy:win64"
  },
  "author": "BigDream Corp",
  "license": "ISC",
  "devDependencies": {
    "electron": "^39.8.8",
    "electron-builder": "^26.8.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "adbkit": "^2.11.1",
    "adbkit-apkreader": "^3.2.0",
    "axios": "^1.15.1",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "firebase": "^12.12.1",
    "google-play-scraper": "^10.1.2",
    "onnxruntime-node": "^1.23.2"
  },
  "build": {
    "productName": "BD-Scanner",
    "appId": "com.bigdream.bdscanner",
    "asar": true,
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/setUpIcon.ico",
      "signtoolOptions": {
        "signingHashAlgorithms": [
          "sha256"
        ],
        "certificateSubjectName": "BigDream Corp",
        "rfc3161TimeStampServer": "http://timestamp.globalsign.com/tsa/r6advanced1"
      }
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "perMachine": true,
      "language": 1042,
      "installerIcon": "assets/setUpIcon.ico",
      "shortcutName": "BD-Scanner",
      "artifactName": "BD-Scanner-${version}.${ext}",
      "uninstallDisplayName": "BD-Scanner"
    },
    "extraResources": [
      {
        "from": "platform-tools/",
        "to": "platform-tools/",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "ios-tools/",
        "to": "ios-tools/",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "pcap_receiver.py",
        "to": "pcap_receiver.py"
      },
      {
        "from": "assets/models",
        "to": "assets/models"
      }
    ],
    "publish": {
      "provider": "github",
      "private": true
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wormsJJG/BigDream"
  }
}
