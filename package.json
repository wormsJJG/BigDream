{
  "name": "BD-SCANNER",
  "version": "2.1.0",
  "description": "BD-Scanner",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "verify:structure": "node scripts/verify-structure.js",
    "test": "npm run verify:structure",
    "reinstall:electron": "node scripts/reinstall-electron.js",
    "build": "npm run verify:structure && electron-builder --dir",
    "pack": "npm run verify:structure && electron-builder",
    "deploy:xos": "electron-builder --mac",
    "deploy:win32": "electron-builder --win --ia32",
    "deploy:win64": "electron-builder --win --x64 --publish always",
    "deploy:win": "npm run deploy:win32 && npm run deploy:win64"
  },
  "author": "BigDream Corp",
  "license": "ISC",
  "devDependencies": {
    "electron": "^39.8.8",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "adbkit": "^2.11.1",
    "adbkit-apkreader": "^3.2.0",
    "axios": "^1.15.1",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "firebase": "^12.12.1",
    "google-play-scraper": "^10.1.2",
    "onnxruntime-node": "^1.23.2"
  },
  "build": {
    "productName": "BD-Scanner",
    "appId": "com.bigdream.bdscanner",
    "asar": true,

    "win": {
      "target": ["nsis"],
      "icon": "assets/setUpIcon.ico",
      "signtoolOptions": {
        "signingHashAlgorithms": ["sha256"],
        "certificateSubjectName": "BigDream Corp",
        "rfc3161TimeStampServer": "http://timestamp.globalsign.com/tsa/r6advanced1"
      }
    },

    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "perMachine": true,
      "language": 1042,
      "installerIcon": "assets/setUpIcon.ico",
      "shortcutName": "BD-Scanner",
      "artifactName": "BD-Scanner-${version}.${ext}",
      "uninstallDisplayName": "BD-Scanner"
    },

    "extraResources": [
      { "from": "platform-tools/", "to": "platform-tools/", "filter": ["**/*"] },
      { "from": "ios-tools/", "to": "ios-tools/", "filter": ["**/*"] },
      { "from": "pcap_receiver.py", "to": "pcap_receiver.py" },
      { "from": "assets/models", "to": "assets/models" }
    ],

    "publish": {
      "provider": "github",
      "private": true
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wormsJJG/BigDream"
  }
}
