{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true
  },
  "include": [
    "main.js",
    "preload.js",
    "renderer.js",
    "src/**/*.js",
    "src/**/*.ts",
    "src/**/*.d.ts",
    "scripts/**/*.js",
    "scripts/**/*.ts"
  ],
  "exclude": [
    "dist",
    "release",
    "node_modules",
    ".ts-build-preview"
  ]
}
